# B站Cookie（可选）
BILIBILI_COOKIE=""

# OpenAI
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-3.5-turbo"

# 飞书
FEISHU_WEBHOOK=""

# Telegram
TELEGRAM_TOKEN=""
TELEGRAM_CHAT_ID=""

# 微信企业号
WECHAT_CORP_ID=""
WECHAT_CORP_SECRET=""
WECHAT_AGENT_ID=""
WECHAT_TO_USER="@all"

# 数据库
DATABASE_URL=sqlite:///data/bili.db

# 日志
LOG_LEVEL=INFO

# 调度间隔（分钟）
VIDEO_CHECK_INTERVAL=10
DYNAMIC_CHECK_INTERVAL=-1

# ASR 语音识别 (whisper=本地模型, qwen=阿里云百炼在线模型)
ASR_PROVIDER=qwen
ASR_API_KEY=sk-xxxxxxxxxxxxxxxxx
ASR_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
ASR_MODEL=qwen3-asr-flash