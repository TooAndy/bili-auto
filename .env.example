# B站Cookie（可选）
BILIBILI_COOKIE=""

# OpenAI
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-3.5-turbo"

# 飞书
FEISHU_WEBHOOK=""

# Telegram
TELEGRAM_TOKEN=""
TELEGRAM_CHAT_ID=""

# 微信企业号
WECHAT_CORP_ID=""
WECHAT_CORP_SECRET=""
WECHAT_AGENT_ID=""
WECHAT_TO_USER="@all"

# 数据库
DATABASE_URL=sqlite:///data/bili.db

# 日志
LOG_LEVEL=INFO

# 调度间隔（分钟）
VIDEO_CHECK_INTERVAL=10
DYNAMIC_CHECK_INTERVAL=-1


# Whisper 语音识别配置
# 模型: tiny|base|small|medium|large
WHISPER_MODEL=small
WHISPER_DEVICE=cpu


# Whisper.cpp 配置（可选，加速识别）
USE_WHISPER_CPP=true
WHISPER_CPP_CLI=/path/to/whisper-cli
WHISPER_CPP_MODEL=/path/to/ggml-small.bin
